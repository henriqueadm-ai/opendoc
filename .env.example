# ═══════════════════════════════════════════════════════════════
# OpenDoc — Variáveis de Ambiente
# Copie para .env e preencha os valores antes de iniciar
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_PASSWORD=opendoc_secret
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Conexão com o banco (formato: postgresql://user:pass@host:port/db)
DATABASE_URL=postgresql://opendoc:opendoc_secret@localhost:5432/opendoc

# Segredo para assinatura JWT (min 32 chars)
# Gere com: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_chars_minimum_secret_key_here

# Chave de criptografia AES-256 (exatamente 64 hex chars = 32 bytes)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_0000000000000000000000000000000000000000000000000000

# ── LLM Providers (ao menos um é obrigatório) ─────────────────
# Google Gemini
GOOGLE_API_KEY=

# OpenRouter (acesso a múltiplos providers)
OPENROUTER_API_KEY=

# ── WhatsApp Business API ──────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=opendoc_verify_2026

# ── Docker Compose Ports ───────────────────────────────────────
SERVER_PORT=3001
DASHBOARD_PORT=3000
